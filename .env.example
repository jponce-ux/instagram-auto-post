# Base de datos
POSTGRES_USER=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB=instagram_app
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/instagram_app

# App
DEBUG=true
SECRET_KEY=your-secret-key-here

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minio-admin-user
MINIO_ROOT_PASSWORD=minio-admin-password
MINIO_BUCKET_NAME=instagram-uploads
MINIO_TUNNEL_HOST=minio-tunnel-host-site
MINIO_SSE_ENABLED=false

# Celery
CELERY_BROKER_URL=redis://redis:6379/0

# Meta / Instagram Webhooks
# Generate a secure random token for webhook verification
# This token is used when Meta subscribes to your webhook endpoint
# The endpoint will be: https://instagramjp.loquinto.com/webhooks/instagram
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-here
META_APP_SECRET=your-meta-app-secret-token-from-instagram-api

# Cloudflare Tunnel
# Get your tunnel token from: Cloudflare Zero Trust dashboard → Networks → Tunnels → Create tunnel
# OR use an existing tunnel's token from the dashboard
TUNNEL_TOKEN=cloudflare-tunnel-token
